[Unit]
Description=Manages docker compose service for traefik (OpenClaw proxy)
Requires=docker.service
After=docker.service

[Service]
WorkingDirectory={{ openclaw_traefik_config_dir }}
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0
Restart=on-failure
StartLimitBurst=3
EnvironmentFile=/etc/environment

[Install]
WantedBy=multi-user.target


